rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isMember() {
      return isSignedIn() && (
        (resource.data.memberIds is list && request.auth.uid in resource.data.memberIds) ||
        (request.resource.data.memberIds is list && request.auth.uid in request.resource.data.memberIds)
      );
    }

    match /apps/{appId} {
      match /tenpos/{tenpoId} {
        match /queue/{queueId} {
          allow read, write: if isSignedIn();
        }
      }

      match /users/{userId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == userId;
      }

      match /general/{tenpoId} {
        match /public_rankings/{rankingId} {
          allow read: if true;
          allow write: if isSignedIn();
        }

        match /matches/{matchId} {
          allow read: if isMember() || (isSignedIn() && resource.data.status == "waiting");
          allow write: if isMember()
            || (isSignedIn()
              && request.resource.data.memberIds is list
              && request.auth.uid in request.resource.data.memberIds);
        }

        match /queue/{queueId} {
          allow read, write: if isSignedIn();
        }
      }
    }
  }
}
