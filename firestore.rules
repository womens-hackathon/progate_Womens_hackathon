rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isTenpoOwner(tenpoId) {
      return isSignedIn() && request.auth.uid == tenpoId;
    }

    function isMember(matchDoc) {
      return isSignedIn() && (
        (matchDoc.data.memberIds is list && request.auth.uid in matchDoc.data.memberIds) ||
        (request.resource.data.memberIds is list && request.auth.uid in request.resource.data.memberIds)
      );
    }

    // アプリごとのデータ
    match /apps/{appId} {
      // 店舗データ - 店舗所有者のみアクセス可能
      match /tenpos/{tenpoId} {
        allow read, write: if isTenpoOwner(tenpoId);

        // キュー管理
        match /queue/{queueId} {
          allow read, write: if isTenpoOwner(tenpoId);
        }
      }

      // ユーザーデータ - 認証済みで読み、所有者のみ書き
      match /users/{userId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }

      // 一般公開データ（/apps/{appId}/general/{tenpoId}/...）
      match /general/{tenpoId} {
        // 公開ランキング - 全員読み取り可能、認証済みのみ書き込み
        match /public_rankings/{rankingId} {
          allow read: if true;
          allow write: if isSignedIn();
        }

        // マッチデータ - メンバーまたはwaiting状態で読み取り、メンバーのみ書き込み
        match /matches/{matchId} {
          allow read: if isMember(resource) ||
                     (isSignedIn() && resource.data.status == "waiting");
          allow write: if isMember(resource) ||
                      (isSignedIn() && request.resource.data.memberIds is list &&
                       request.auth.uid in request.resource.data.memberIds);

          match /scores/{uid} {
            allow read, write: if isSignedIn();
          }
        }

        // キュー - 認証済みのみ
        match /queue/{queueId} {
          allow read, write: if isSignedIn();
        }
      }
    }
  }
}
